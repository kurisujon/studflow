# ---------------------------------------------------------------------------
# Distill API — Environment Variables
# Copy this file to .env and fill in your values.
# ---------------------------------------------------------------------------

# Application
APP_NAME="Studflow API"
APP_VERSION="0.1.0"
DEBUG=false
AUTO_CREATE_TABLES=false

# PostgreSQL — psycopg3 (pre-compiled binary, Python 3.14 compatible)
# Local format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DB_NAME
# Supabase direct format:
# postgresql+psycopg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/distill

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Supabase Storage
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=documents
SUPABASE_STORAGE_FOLDER=uploads

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=
GEMINI_MAX_RETRIES=3
# Gemini text-embedding-004 returns the 768-dimension vectors stored in pgvector.
GEMINI_EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=24
RAG_TOP_K=5
RAG_CLUSTER_MAX_CHUNKS=5

# Celery's durable document pipeline retries unfinished stages only.
DOCUMENT_PROCESSING_MAX_RETRIES=3
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# YouTube
YOUTUBE_API_KEY=

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-strong-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Clerk Auth
# Backend can derive CLERK_ISSUER and CLERK_JWKS_URL from CLERK_PUBLISHABLE_KEY.
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3002","http://127.0.0.1:3000","http://127.0.0.1:3002"]
